  "schema": {
    "template_source": {
      "file": "seq_template.xlsx",
      "sheet": "Metadata",
      "geo_last_updated_note": "This file was last updated by GEO on Dec 17, 2024.",
      "shared_cv_source": "SRA_metadata.xlsx (SRA_data validations + Library and Platform Terms)"
    },
    "sections": {
      "study": {
        "description": "STUDY section describes the overall GEO Series (GSE) record. Content is displayed publicly and should summarize the experiment at a study level.",
        "fields": {
          "*title": {
            "field": "title",
            "template_key": "*title",
            "required": "required",
            "description": "Overall study title for the GEO Series (GSE). Should be short but descriptive and unique. Avoid overly generic titles.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "*summary (abstract)": {
            "field": "summary (abstract)",
            "template_key": "*summary (abstract)",
            "required": "required",
            "description": "Study-level abstract/summary for the GEO Series. Provide background, experimental context, what was measured, and the main goals. 1\u20133 paragraphs is typical.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "*experimental design": {
            "field": "experimental design",
            "template_key": "*experimental design",
            "required": "required",
            "description": "Describe the experimental design and variables: groups/conditions, timepoints, replicates, controls, randomization, and how samples relate to conditions. Mention any key covariates.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "contributor": {
            "field": "contributor",
            "template_key": "contributor",
            "required": "optional",
            "description": "People who contributed to generating the dataset (often authors). Use full names. Include multiple rows if needed.",
            "expected_value": "string or list",
            "examples": [],
            "validation_hints": []
          },
          "supplementary file": {
            "field": "supplementary file",
            "template_key": "supplementary file",
            "required": "optional",
            "description": "Optional additional files to accompany the GEO Series record (e.g., README, sample metadata CSV, QC reports). Provide file names as they will appear in the submission.",
            "expected_value": "string or list",
            "examples": [],
            "validation_hints": []
          }
        }
      },
      "samples": {
        "description": "SAMPLES section defines one GEO Sample (GSM) per row (one library per row). Titles, library names, and raw files must be unique. Use extra raw/processed columns for technical replicates or multiple outputs.",
        "fields": {
          "*library name": {
            "field": "library name",
            "template_key": "*library name",
            "required": "required",
            "description": "Unique identifier for each library/sample in this submission. Often corresponds to internal sample ID or library prep ID. Must be unique across rows.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "*title": {
            "field": "title",
            "template_key": "*title",
            "required": "required",
            "description": "Short title for the GEO Sample (GSM). Should uniquely identify the biological material and condition (e.g., 'WT lung, day 7, replicate 1').",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "*library strategy": {
            "field": "library strategy",
            "template_key": "*library strategy",
            "required": "required",
            "description": "Sequencing strategy (e.g., RNA-Seq, ChIP-Seq, ATAC-Seq, WGS, scRNA-Seq, etc.). Use controlled terms from GEO/SRA when possible.",
            "expected_value": "string",
            "examples": [
              "WGA",
              "WGS",
              "WXS",
              "RNA-Seq",
              "miRNA-Seq",
              "WCS",
              "CLONE",
              "POOLCLONE"
            ],
            "validation_hints": [
              "Prefer an exact value from controlled_vocabulary.library_strategy.",
              "Use the same strategy label that would also be used in the SRA report for this library."
            ],
            "allowed_terms_ref": "controlled_vocabulary.library_strategy"
          },
          "*organism": {
            "field": "organism",
            "template_key": "*organism",
            "required": "required",
            "description": "Scientific name of the organism (e.g., Homo sapiens, Mus musculus). Should match NCBI Taxonomy naming.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "**tissue": {
            "field": "tissue",
            "template_key": "**tissue",
            "required": "conditional",
            "description": "Tissue of origin (conditional). Use standardized anatomical terms when possible (e.g., UBERON). For single-cell, may be broader organ/tissue source.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "**cell line": {
            "field": "cell line",
            "template_key": "**cell line",
            "required": "conditional",
            "description": "Cell line name if applicable (conditional). Include vendor/catalog and/or accession if available (e.g., ATCC). Leave blank for primary tissue without cell line.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "**cell type": {
            "field": "cell type",
            "template_key": "**cell type",
            "required": "conditional",
            "description": "Cell type (conditional). For scRNA/immune studies, use standard terms (e.g., Cell Ontology) when possible.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "genotype": {
            "field": "genotype",
            "template_key": "genotype",
            "required": "optional",
            "description": "Genotype of the sample/organism (e.g., WT, knockout, transgenic allele). Include relevant loci and zygosity if known.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "treatment": {
            "field": "treatment",
            "template_key": "treatment",
            "required": "optional",
            "description": "Treatments or perturbations applied (drug, infection, stimulation, vaccination), including dose, route, duration, and time since treatment.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "batch": {
            "field": "batch",
            "template_key": "batch",
            "required": "optional",
            "description": "Batch identifier capturing known technical batches (prep batch, sequencing run, lane, date). Helps downstream users account for batch effects.",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "*molecule": {
            "field": "molecule",
            "template_key": "*molecule",
            "required": "required",
            "description": "Molecule extracted for library prep (e.g., total RNA, polyA RNA, genomic DNA, chromatin, nuclei).",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "*single or paired-end": {
            "field": "single or paired-end",
            "template_key": "*single or paired-end",
            "required": "required",
            "description": "Indicate whether reads are single-end or paired-end. Must be consistent with raw files provided.",
            "expected_value": "string",
            "examples": [
              "single",
              "paired"
            ],
            "validation_hints": [
              "Use the shared controlled vocabulary values exactly: single or paired.",
              "Choice must agree with the number and pairing pattern of raw files."
            ],
            "allowed_terms_ref": "controlled_vocabulary.library_layout"
          },
          "*instrument model": {
            "field": "instrument model",
            "template_key": "*instrument model",
            "required": "required",
            "description": "Sequencing instrument model (e.g., Illumina NovaSeq 6000, NextSeq 2000). Prefer exact model names.",
            "expected_value": "string",
            "examples": [
              "HiSeq X Five",
              "HiSeq X Ten",
              "Illumina Genome Analyzer",
              "Illumina Genome Analyzer II",
              "Illumina Genome Analyzer IIx",
              "Illumina HiScanSQ",
              "Illumina HiSeq 1000",
              "Illumina HiSeq 1500",
              "Illumina HiSeq 2000",
              "Illumina HiSeq 2500"
            ],
            "validation_hints": [
              "Prefer an exact value from controlled_vocabulary.instrument_model_flat.",
              "If platform is inferable, choose an instrument model that belongs to the matching controlled_vocabulary.instrument_model_by_platform entry."
            ],
            "allowed_terms_ref": "controlled_vocabulary.instrument_model_flat"
          },
          "description": {
            "field": "description",
            "template_key": "description",
            "required": "optional",
            "description": "Additional sample/library description. Useful for specifying finer details not captured elsewhere (e.g., isolation method, enrichment, fraction, indexing scheme).",
            "expected_value": "string",
            "examples": [],
            "validation_hints": []
          },
          "processed data file": {
            "field": "processed data file",
            "template_key": "processed data file",
            "required": "optional",
            "description": "Name of processed data file(s) associated with this sample/library (e.g., count matrix, peak calls, BAM, bedGraph). If multiple, list each in separate 'processed data file' columns.",
